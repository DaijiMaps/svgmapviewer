{
  "name": "svgmapviewer",
  "version": "0.5.0",
  "keywords": [
    "SVG",
    "map",
    "viewer"
  ],
  "license": "ISC",
  "author": "Daiji Maps",
  "repository": {
    "url": "https://github.com/DaijiMaps/svgmapviewer"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./address": "./dist/lib/address/index.js",
    "./box": "./dist/lib/box/prefixed/index.js",
    "./carto": "./dist/lib/carto/index.js",
    "./carto-objects": "./dist/lib/carto/objects/index.js",
    "./carto-symbols": "./dist/lib/carto/symbols/index.js",
    "./geo": "./dist/lib/geo/index.js",
    "./map": "./dist/lib/map/index.js",
    "./map-floors": "./dist/lib/map/floors/index.js",
    "./matrix": "./dist/lib/matrix/prefixed/index.js",
    "./search": "./dist/lib/search/index.js",
    "./tuple": "./dist/lib/tuple/index.js",
    "./vec": "./dist/lib/vec/prefixed/index.js"
  },
  "scripts": {
    "build": "tsgo -b && rslib build",
    "lint": "eslint . && oxlint --type-aware --type-check",
    "publish:jsr": "pnpm dlx jsr publish",
    "test": "rstest",
    "test:dev": "rstest --watch"
  },
  "dependencies": {
    "@xstate/react": "^6.1.0",
    "@xstate/store": "^3.17.5",
    "animejs": "^4.4.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.66",
    "flatbush": "^4.6.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "type-fest": "^5.7.0",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.11",
    "@rsbuild/plugin-react": "^2.0.1",
    "@rslib/core": "^0.21.5",
    "@rstest/core": "^0.10.3",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "happy-dom": "^20.10.2",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*": "oxfmt --write"
  }
}
