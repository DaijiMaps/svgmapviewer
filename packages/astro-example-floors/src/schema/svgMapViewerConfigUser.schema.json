{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "root": {
      "type": "string"
    },
    "href": {
      "type": "string"
    },
    "width": {
      "type": "number"
    },
    "height": {
      "type": "number"
    },
    "origViewBox": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      },
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false
    },
    "origBoundingBox": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      },
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false
    },
    "fontSize": {
      "type": "number"
    },
    "backgroundColor": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "copyright": {
      "type": "string"
    },
    "zoomFactor": {
      "type": "number"
    },
    "searchAddresses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "floorPos": {
            "type": "object",
            "properties": {
              "coord": {
                "type": "object",
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  }
                },
                "required": ["x", "y"],
                "additionalProperties": false
              },
              "fidx": {
                "type": "number"
              }
            },
            "required": ["coord", "fidx"],
            "additionalProperties": false
          }
        },
        "required": ["address", "floorPos"],
        "additionalProperties": false
      }
    },
    "searchNames": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["name", "addresses"],
        "additionalProperties": false
      }
    },
    "floorsConfig": {
      "type": "object",
      "properties": {
        "initialFidx": {
          "type": "number"
        },
        "floors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "href": {
                "type": "string"
              },
              "file": {
                "type": "string"
              },
              "labels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "attrs": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {
                        "anyOf": [
                          {
                            "type": "null"
                          },
                          {
                            "type": "number"
                          },
                          {
                            "type": "string"
                          }
                        ]
                      }
                    },
                    "children": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "attrs": {
                            "type": "object",
                            "propertyNames": {
                              "type": "string"
                            },
                            "additionalProperties": {
                              "anyOf": [
                                {
                                  "type": "null"
                                },
                                {
                                  "type": "number"
                                },
                                {
                                  "type": "string"
                                }
                              ]
                            }
                          },
                          "text": {
                            "anyOf": [
                              {
                                "type": "null"
                              },
                              {
                                "type": "string"
                              }
                            ]
                          }
                        },
                        "required": ["attrs", "text"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["attrs", "children"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["name", "href"],
            "additionalProperties": false
          }
        }
      },
      "required": ["initialFidx", "floors"],
      "additionalProperties": false
    },
    "uiConfig": {
      "type": "object",
      "properties": {
        "showGuides": {
          "type": "boolean"
        }
      },
      "required": ["showGuides"],
      "additionalProperties": false
    }
  },
  "additionalProperties": {}
}
